{
  "name": "create-app-elysia",
  "version": "0.1.0",
  "description": "cli 生成 elysia 项目",
  "homepage": "https://github.com/QLing-yes/create-app-elysia/tree/main/packages/create-app-elysia#readme",
  "license": "MIT",
  "type": "module",
  "bin": {
    "create-app-elysia": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QLing-yes/create-app-elysia.git"
  },
  "scripts": {
    "dev": "bun run  src/index.ts  my-elysia-app",
    "build": "bun build src/index.ts --outdir ./dist --format esm --target node",
    "start": "bun run dist/index.js",
    "gen-types": "bun run scripts/01json2type.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "enquirer-esm": "^2.3.6-ext.1",
    "minimist": "^1.2.8",
    "strip-json-comments": "^5.0.3",
    "tasuku": "^2.3.0",
    "ts-dedent": "^2.2.0"
  },
  "peerDependencies": {
    "typescript": ">=4.5.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "quicktype": "^23.2.6"
  }
}